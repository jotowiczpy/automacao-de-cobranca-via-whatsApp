                    df.at[index, "status"] = "enviado"

            except pyautogui.ImageNotFoundException:
                # Imagem não encontrada = número é válido, mensagem enviada
                print(f"✅ Mensagem enviada para {nome}!")
                df.at[index, "status"] = "enviado"

            envios_realizados += 1

            # Pausa longa periódica para simular comportamento humano
            if envios_realizados % PAUSA_A_CADA == 0:
                pausa_longa = random.randint(PAUSA_LONGA_MIN, PAUSA_LONGA_MAX)
                print(f"⏸️  Pausa longa de {pausa_longa}s após {envios_realizados} envios...")
                time.sleep(pausa_longa)
